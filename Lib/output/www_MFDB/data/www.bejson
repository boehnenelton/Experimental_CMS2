            background-color: #f5f5f5;\n            position: relative;\n            border-bottom: 1px solid #f0f0f0;\n        }\n\n        .product-image-inner {\n            position: absolute;\n            inset: 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            flex-direction: column;\n            gap: 4px;\n            color: #bbb;\n            font-size: 0.72rem;\n        }\n\n        .product-image-icon {\n            font-size: 2rem;\n            opacity: 0.4;\n        }\n\n        .product-badge {\n            position: absolute;\n            top: 8px;\n            left: 8px;\n            background-color: var(--primary);\n            color: #fff;\n            font-size: 0.7rem;\n            font-weight: 600;\n            padding: 2px 7px;\n            border-radius: 3px;\n        }\n\n        .product-card-body {\n            padding: 10px 12px 12px 12px;\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .product-category {\n            font-size: 0.72rem;\n            text-transform: uppercase;\n            color: var(--primary);\n            font-weight: 600;\n            letter-spacing: 0.05em;\n            margin-bottom: 4px;\n        }\n\n        .product-name {\n            font-weight: 600;\n            font-size: 0.9rem;\n            margin: 0 0 4px 0;\n            line-height: 1.4;\n        }\n\n        .product-description {\n            font-size: 0.8rem;\n            color: #666;\n            margin: 0 0 10px 0;\n            line-height: 1.4;\n        }\n\n        .product-card-footer {\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            margin-top: auto;\n        }\n\n        .product-price {\n            font-weight: 600;\n            font-size: 1rem;\n            color: #1a1a1a;\n        }\n\n        .product-price-old {\n            font-size: 0.8rem