24px; background-color: #f8f9fa; border: 1px solid #e5e5e5; border-radius: 6px; padding: 16px; text-align: center; font-size: 0.85rem; color: #666666; line-height: 1.6; }\n        .page-footer a { color: var(--primary); text-decoration: none; }\n        .page-footer a:hover { text-decoration: underline; }\n        .global-docked-footer { position: fixed; bottom: 0; left: 0; width: 100%; background-color: #ffffff; border-top: 1px solid #e5e5e5; padding: 12px 24px; padding-bottom: calc(12px + env(safe-area-inset-bottom)); text-align: center; font-size: 0.85rem; color: #666666; z-index: 900; }\n        .global-docked-footer a { color: var(--primary); }\n        .mobile-sidebar { position: fixed; top: 0; left: -300px; width: 280px; height: 100vh; background: #ffffff; border-right: 1px solid #e5e5e5; z-index: 1000; transition: left 0.3s ease; padding: 24px; box-shadow: 2px 0 8px rgba(0,0,0,0.1); }\n        .mobile-sidebar.open { left: 0; }\n        .sidebar-overlay { display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 999; }\n        .sidebar-overlay.open { display: block; }\n        .sidebar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }\n        .sidebar-title { font-weight: 600; font-size: 1.25rem; color: #1a1a1a; }\n        .close-sidebar { cursor: pointer; font-weight: 600; font-size: 1.2rem; color: #1a1a1a; }\n        @container (max-width: 768px) {\n            body { padding-bottom: 100px; }\n            .container { grid-template-columns: 1fr; }\n            .left-column, .right-column { display: none; }\n            .global-docked-footer { padding-bottom: calc(16px + env(safe-area-inset-bottom)); }\n        }\n\n        /* === Podcast Feed Styles === */\n        .podcast-show-card {\n            display: flex;\n            gap: 14px;\n            align-items: flex-start;\n            background-color: #f8f9fa;\n            border: 1px solid #e5e5e5;\n            border-radius: 6px;\n            padding: 14px;\n            margin-bottom: 16px;\n        }\n\n        .podcast-show-art {\n            width: 72px;\n            min-width: 72px;\n            height: 72px;\n            background-color: #e5e5e5;\n            border-radius: 6px;\n            border: 1px solid #ddd;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 1.6rem;\n        }\n\n        .podcast-show-info {\n            flex: 1;\n        }\n\n        .podcast-show-name {\n            font-weight: 600;\n            font-size: 1rem;\n            margin: 0 0 4px 0;\n        }\n\n        .podcast-show-desc {\n            font-size: 0.85rem;\n            color: #555;\n            margin: 0 0 8px 0;\n            line-height: 1.5;\n        }\n\n        .podcast-subscribe-btn {\n            display: inline-block;\n            padding: 4px 14px;\n            background-color: var(--primary);\n            color: #fff;\n            border-radius: 4px;\n            font-size: 0.8rem;\n            font-weight: 600;\n            cursor: pointer;\n        }\n\n        .podcast-subscribe-btn:hover {\n            opacity: 0.9;\n            text-decoration: none;\n        }\n\n        .podcast-episodes-label {\n            font-weight: 600;\n            font-size: 0.85rem;\n            color: #888;\n            text-transform: uppercase;\n            letter-spacing: 0.06em;\n            margin-bottom: 8px;\n        }\n\n        .podcast-feed {\n            display: flex;\n            flex-direction: column;\n            gap: 0;\n        }\n\n        .podcast-episode {\n            display: flex;\n            gap: 14px;\n            align-items: center;\n            padding: 14px 0;\n            border-bottom: 1px solid #f0f0f0;\n        }\n\n        .podcast-episode:last-child {\n            border-bottom: none;\n        }\n\n        .podcast-play-btn {\n            width: 38px;\n            min-width: 38px;\n            height: 38px;\n            border-radius: 50%;\n            border: 2px solid var(--primary);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            color: var(--primary);\n            font-size: 0.85rem;\n            cursor: pointer;\n            padding-left: 2px; /* optical centering for play triangle */\n        }\n\n        .podcast-play-btn:hover {\n            background-color: var(--primary);\n            color: #fff;\n        }\n\n        .podcast-ep-body {\n            flex: 1;\n        }\n\n        .podcast-ep-number {\n            font-size: 0.72rem;\n            text-transform: uppercase;\n            color: var(--primary);\n            font-weight: 600;\n            letter-spacing: 0.05em;\n            margin-bottom: 3px;\n        }\n\n        .podcast-ep-title {\n            font-weight: 600;\n            font-size: 0.95rem;\n            margin: 0 0 4px 0;\n            line-height: 1.4;\n        }\n\n        .podcast-ep-desc {\n            font-size: 0.83rem;\n            color: #666;\n            margin: 0 0 5px 0;\n        }\n\n        .podcast-ep-meta {\n            font-size: 0.76rem;\n            color: #aaa;\n        }\n\n        .podcast-pagination {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 6px;\n            margin-top: 24px;\n        }\n\n        .podcast-page-btn {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            width: 34px;\n            height: 34px;\n            border-radius: 4px;\n            border: 1px solid #e5e5e5;\n            font-size: 0.875rem;\n            cursor: pointer;\n            color: #444;\n            background: #fff;\n        }\n\n        .podcast-page-btn.active {\n            background-color: var(--primary);\n            color: #fff;\n            border-color: var(--primary);\n            font-weight: 600;\n        }\n\n        .podcast-page-btn:hover:not(.active) {\n            background-color: #f5f5f5;\n        }\n    }\n}\n\n/* From Template-Standard-Feed-Product-body-component.html */\n@layer components.feed_product {\n    .c-feed-product {\n        * { box-sizing: border-box; }\n        body { margin: 0; padding: 0; font-family: 'Inter', sans-serif; background-color: #ffffff; color: #1a1a1a; padding-bottom: 60px; }\n        a { color: var(--primary); text-decoration: none; }\n        a:hover { text-decoration: underline; }\n        .emphasis { color: var(--primary); }\n        header { display: flex; align-items: center; padding: 12px 24px; border-bottom: 1px solid #e5e5e5; }\n        .hamburger { cursor: pointer; display: flex; flex-direction: column; gap: 4px; margin-right: 24px; padding: 4px; }\n        .hamburger span { display: block; width: 24px; height: 2px; background-color: #1a1a1a; }\n        .header-logo { font-weight: 600; font-size: 1.25rem; }\n        .breadcrumbs { padding: 8px 24px; border-bottom: 1px solid #f0f0f0; font-size: 0.875rem; color: #666666; }\n        .breadcrumbs a { color: var(--primary); }\n        .container { display: grid; grid-template-columns: 250px 1fr 250px; gap: 24px; padding: 12px 24px 24px 24px; min-height: calc(100vh - 120px); }\n        .sidebar-links { display: flex; flex-direction: column; }\n        .sidebar-links a { padding: 4px 8px; margin-bottom: 2px; font-size: 0.9rem; border-radius: 4px; }\n        .sidebar-links a:hover { background-color: #f5f5f5; }\n        .left-column, .mobile-sidebar { display: flex; flex-direction: column; height: 100%; }\n        .sidebar-top { flex: 3 1 0; overflow-y: auto; padding-bottom: 16px; }\n        .sidebar-bottom { flex: 1 1 0; background-color: #f8f9fa; border: 1px solid #e5e5e5; border-radius: 6px; padding: 16px; display: flex; align-items: center; justify-content: center; color: #666; font-size: 0.9rem; text-align: center; }\n        .main-link