ion\": \"Professional grade source code repositories.\", \"url\": \"../libraries/index.html\", \"action_url\": null, \"action_label\": \"RUN\", \"children\": []}, {\"id\": \"cat_3\", \"parent_id\": \"Utilities\", \"title\": \"Utilities\", \"description\": \"Interactive high-performance standalone tools.\", \"url\": \"../apps/index.html\", \"action_url\": null, \"action_label\": \"RUN\", \"children\": []}, {\"id\": \"inf1\", \"parent_id\": \"Contact Us\", \"title\": \"Contact Us\", \"description\": \"Get in touch\", \"url\": \"../contact.html\", \"action_url\": null, \"action_label\": \"RUN\", \"children\": []}];\n    </script>\n</div>\n\n        </aside>\n\n        <main class=\"app-main\">\n            <div class=\"breadcrumb-strip\">SITE / ROOT / <span></span></div>\n            \n            <div class=\"content-container\">\n                <!-- ExpCSS RECONSTRUCTION | Category Feed Skeleton v2.0 -->\n<!-- Dynamic Feed Scaffolding: Supports Blog, News, Products, and Masonry -->\n\n<div class=\"category-header mb-12\">\n    <div class=\"content-card\">\n        <h1 class=\"text-3xl font-black text-[#fe3626] uppercase tracking-tighter\">Education</h1>\n        <div class=\"text-gray-400 mt-2 font-mono text-sm\">// In-depth learning paths and crash courses.</div>\n    </div>\n</div>\n\n\n    <div class=\"c-feed-blog\">\n        <div class=\"blog-feed\">\n            \n                <div class=\"blog-card\">\n                    <div class=\"blog-thumb\">IMG</div>\n                    <div class=\"blog-card-body\">\n                        <p class=\"blog-card-title\"><a href=\"bejson-&-mfdb-crash-course/index.html\">BEJSON & MFDB Crash Course</a></p>\n                        <p class=\"blog-card-excerpt\">Mastering the StandardComplete guide to positional integrity and multi-file database orchestration.</p>\n                        <span class=\"blog-card-meta\">2026-05-15T07:27:57Z</span>\n                    </div>\n                </div>\n        </div>\n    </div>\n\n\n\n            </div>\n\n            \n\n            <!-- BLOCK: FOOTER -->\n            <footer class=\"mt-20\">\n                <!-- Component: Footer Status Feed | Type: Footer Fragment | Version: 1.0.0 -->\n<footer class=\"c-footer c-footer-status\">\n    <div class=\"c-footer-status__label\">SYSTEM_LOG:</div>\n    <div class=\"c-footer-status__ticker\">\n        <div class=\"c-footer-status__item\"><div class=\"c-footer-status__pulse\"></div> NODE_MASTER synchronized [0.4ms]</div>\n        <div class=\"c-footer-status__item\"><div class=\"c-footer-status__pulse\"></div> NEW_JOB queued: REPO_AUDIT_Q2</div>\n        <div class=\"c-footer-status__item\"><div class=\"c-footer-status__pulse\"></div> POL_ENFORCER: Integrity verified</div>\n        <div class=\"c-footer-status__item\"><div class=\"c-footer-status__pulse\"></div> HEARTBEAT: 104bpm (Stable)</div>\n    </div>\n</footer>\n        <div class=\"c-footer-links\" style=\"background: #050505; border-top: 1px solid #222; padding: 2rem; margin-top: 4rem;\">\n            <div class=\"container mx-auto grid grid-cols-1 md:grid-cols-3 gap-8\">\n                <div>\n                    <h4 style=\"color: #DE2626; font-weight: 800; margin-bottom: 1rem;\">CONTACT</h4>\n                    <p style=\"font-size: 0.8rem; color: #888;\">Email: info@boehnenelton.dev</p>\n                    <p style=\"font-size: 0.8rem; color: #888;\">Location: Distributed Node</p>\n                </div>\n                <div>\n                    <h4 style=\"color: #DE2626; font-weight: 800; margin-bottom: 1rem;\">RESOURCES</h4>\n                    <ul style=\"list-style: none; padding: 0; font-size: 0.8rem; color: #888;\">\n                        <li><a href=\"#\" style=\"color: inherit;\">Documentation</a></li>\n                        <li><a href=\"#\" style=\"color: inherit;\">API Status</a></li>\n                    </ul>\n                </div>\n                <div>\n                    <h4 style=\"color: #DE2626; font-weight: 800; margin-bottom: 1rem;\">LEGAL</h4>\n                    <ul style=\"list-style: none; padding: 0; font-size: 0.8rem; color: #888;\">\n                        <li><a href=\"#\" style=\"color: inherit;\">Privacy Policy</a></li>\n                        <li><a href=\"#\" style=\"color: inherit;\">Terms of Service</a></li>\n                    </ul>\n                </div>\n            </div>\n        </div>\n        \n            </footer>\n        </main>\n    </div>\n\n    <script>\n        const btn = document.getElementById('navToggle');\n        const sidebar = document.getElementById('sidebar');\n        const overlay = document.getElementById('overlay');\n\n        function toggle() {\n            const isMobile = window.innerWidth <= 1024;\n            if (isMobile) {\n                sidebar.classList.toggle('active');\n                overlay.classList.toggle('active');\n            } else {\n                sidebar.classList.toggle('collapsed');\n            }\n        }\n\n        btn.addEventListener('click', toggle);\n        overlay.addEventListener('click', toggle);\n\n        lucide.createIcons();\n    </script>\n</body>\n</html>",
