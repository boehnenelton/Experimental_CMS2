tml3_update_breadcrumbs = function(cid, itemId) {\n            const bcContainer = document.querySelector(\"#\" + cid + \" .c-html3-list__breadcrumbs\");\n            if (!bcContainer) return;\n            \n            const data = window.html3_list_data[cid];\n            const path = [];\n            let curr = itemId;\n            \n            while(curr) {\n                const item = data.find(i => i.id === curr);\n                if (item) {\n                    path.unshift(item.title);\n                    curr = item.parent_id;\n                } else break;\n            }\n            \n            bcContainer.innerHTML = path.map((name, i) => \n                \"<span class='c-html3-list__breadcrumb-item \" + (i === path.length - 1 ? \"active\" : \"\") + \"'>\" + name + \"</span>\"\n            ).join(\"\");\n        };\n    }\n</script>\n\n<div id=\"lst_1779508274940\" class=\"c-html3-list c-html3-list--tree\">\n    <div class=\"c-html3-list__breadcrumbs\">SELECT NODE TO VIEW PATH</div>\n    <div style=\"display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;border-bottom:1px solid #333;padding-bottom:0.8rem;\">\n        <div style=\"color:#DE2626;font-weight:bold;letter-spacing:2px;text-transform:uppercase;\">EXPLORE SITE</div>\n        <div style=\"font-size:0.7rem;color:#555;\">v1.3.2</div>\n    </div>\n    <ul class=\"c-html3-list__tree\"><li class=\"c-html3-list__item\"><div class=\"c-html3-list__content\" onclick=\"window.html3_list_toggle(this, 'lst_1779508274940', 'inf1');\"><div class=\"c-html3-list__toggle\">[o]</div><div class=\"c-html3-list__item-info\"><div class=\"c-html3-list__item-title\">Contact Us</div><div class=\"c-html3-list__item-desc\">Get in touch</div></div></div></li><li class=\"c-html3-list__item\"><div class=\"c-html3-list__content\" onclick=\"window.html3_list_toggle(this, 'lst_1779508274940', 'cat_1');\"><div class=\"c-html3-list__toggle\">[o]</div><div class=\"c-html3-list__item-info\"><div clas