       display: flex;\n            gap: 20px;\n            align-items: center;\n            background: #f8f9fa;\n            border: 1px solid #e5e5e5;\n            border-radius: 6px;\n            padding: 16px;\n            margin-bottom: 16px;\n            flex-wrap: wrap;\n        }\n\n        .review-score-block {\n            text-align: center;\n            min-width: 80px;\n        }\n\n        .review-score-big {\n            font-size: 2.8rem;\n            font-weight: 600;\n            color: var(--primary);\n            line-height: 1;\n        }\n\n        .review-stars-row {\n            font-size: 1rem;\n            color: var(--primary);\n            letter-spacing: 1px;\n            margin: 4px 0;\n        }\n\n        .review-score-count {\n            font-size: 0.78rem;\n            color: #999;\n        }\n\n        .review-bars {\n            flex: 1;\n            display: flex;\n            flex-direction: column;\n            gap: 5px;\n        }\n\n        .review-bar-row {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            font-size: 0.78rem;\n            color: #777;\n        }\n\n        .review-bar-label {\n            min-width: 32px;\n            text-align: right;\n        }\n\n        .review-bar-track {\n            flex: 1;\n            height: 6px;\n            background: #e5e5e5;\n            border-radius: 3px;\n            overflow: hidden;\n        }\n\n        .review-bar-fill {\n            height: 100%;\n            background-color: var(--primary);\n            border-radius: 3px;\n        }\n\n        .review-bar-pct {\n            min-width: 28px;\n        }\n\n        .review-controls {\n            display: flex;\n            align-items: center;\n            gap: 8px;\n            flex-wrap: wrap;\n            margin-bottom: 14px;\n        }\n\n        .review-filter-btn {\n            padding: 4px 12px;\n            border-radius: 4px;\n            border: 1px solid #e5e5e5;\n            font-size: 0.8rem;\n            cursor: pointer;\n            color: #444;\n            background: #fff;\n        }\n\n        .review-filter-btn.active, .review-filter-btn:hover {\n            background-color: var(--primary);\n            color: #fff;\n            border-color: var(--primary);\n        }\n\n        .review-feed {\n            display: flex;\n            flex-direction: column;\n            gap: 0;\n        }\n\n        .review-item {\n            padding: 16px 0;\n            border-bottom: 1px solid #f0f0f0;\n        }\n\n        .review-item:last-child {\n            border-bottom: none;\n        }\n\n        .review-item-header {\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            margin-bottom: 8px;\n            flex-wrap: wrap;\n        }\n\n        .review-avatar {\n            width: 34px;\n            height: 34px;\n            border-radius: 50%;\n            background-color: #e5e5e5;\n            border: 1px solid #ddd;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 0.85rem;\n            color: #888;\n            font-weight: 600;\n        }\n\n        .review-author-block {\n            flex: 1;\n        }\n\n        .review-author-name {\n            font-weight: 600;\n            font-size: 0.9rem;\n            margin: 0;\n        }\n\n        .review-author-meta {\n            font-size: 0.76rem;\n            color: #aaa;\n        }\n\n        .review-item-stars {\n            font-size: 0.9rem;\n            color: var(--primary);\n            letter-spacing: 1px;\n        }\n\n        .review-item-title {\n            font-weight: 600;\n            font-size: 0.9rem;\n            margin: 0 0 6px 0;\n        }\n\n        .review-item-body {\n            font-size: 0.875rem;\n            color: #444;\n            line-height: 1.6;\n            margin: 0 0 8px 0;\n        }\n\n        .review-helpful-row {\n            font-size: 0.78rem;\n            color: #999;\n        }\n\n        .review-helpful-row a {\n            font-size: 0.78rem;\n        }\n\n        .review-pagination {\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 6px;\n            margin-top: 24px;\n        }\n\n        .review-page-btn {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            width: 34px;\n            height: 34px;\n            border-radius: 4px;\n            border: 1px solid #e5e5e5;\n            font-size: 0.875rem;\n            cursor: pointer;\n            color: #444;\n            background: #fff;\n        }\n\n        .review-page-btn.active {\n            background-color: var(--primary);\n            color: #fff;\n            border-color: var(--primary);\n            font-weight: 600;\n        }\n\n        .review-page-btn:hover:not(.active) {\n            background-color: #f5f5f5;\n        }\n    }\n}\n\n/* From Template-Standard-Feed-Video-body-component.html */\n@layer components.feed_video {\n    .c-feed-video {\n        * { box-sizing: border-box; }\n        body { margin: 0; padding: 0; font-family: 'Inter', sans-serif; background-color: #ffffff; color: #1a1a1a; padding-bottom: 60px; }\n        a { color: var(--primary); text-decoration: none; }\n        a:hover { text-decoration: underline; }\n        .emphasis { color: var(--primary); }\n        header { display: flex; align-items: center; padding: 12px 24px; border-bottom: 1px solid #e5e5e5; }\n        .hamburger { cursor: pointer; display: flex; flex-direction: column; gap: 4px; margin-right: 24px; padding: 4px; }\n        .hamburger span { display: block; width: 24px; height: 2px; background-color: #1a1a1a; }\n        .header-logo { font-weight: 600; font-size: 1.25rem; }\n        .breadcrumbs { padding: 8px 24px; border-bottom: 1px solid #f0f0f0; font-size: 0.8