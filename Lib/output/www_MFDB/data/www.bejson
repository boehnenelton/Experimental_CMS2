        .article-meta span { margin-right:16px; }\n        .article-body p { line-height:1.75; margin:0 0 16px; font-size:0.975rem; }\n        .article-body h2 { font-size:1.15rem; margin:24px 0 8px; }\n        .pull-quote { border-left:4px solid var(--primary); margin:20px 0; padding:12px 20px; background:#fff5f5; font-style:italic; font-size:1.05rem; color:#333; }\n        .article-tags { display:flex; gap:8px; flex-wrap:wrap; margin-top:20px; }\n        .tag { padding:3px 10px; background:#f0f0f0; border-radius:20px; font-size:0.8rem; color:#555; }\n\n    \n\n/* Search Results STYLES */\n.search-bar-wrap { margin-bottom: 24px; }\n.search-input-group { display: flex; gap: 8px; }\n.search-input { flex: 1; padding: 12px; border: 1px solid #e5e5e5; border-radius: 6px; font-size: 1rem; }\n.search-input:focus { outline: none; border-color: var(--primary); }\n.search-btn { padding: 0 20px; background: var(--primary); color: #fff; border: none; border-radius: 6px; font-weight: 600; cursor: pointer; }\n.result-count { font-size: 0.9rem; color: #666; margin-bottom: 20px; border-bottom: 1px solid #f0f0f0; padding-bottom: 10px; }\n.search-result-item { margin-bottom: 24px; }\n.result-title { font-size: 1.15rem; font-weight: 600; color: var(--primary); margin-bottom: 4px; display: block; }\n.result-link { font-size: 0.85rem; color: #1a7f37; margin-bottom: 6px; display: block; }\n.result-snippet { font-size: 0.95rem; color: #444; line-height: 1.5; }\n.pagination { display: flex; gap: 8px; margin-top: 40px; }\n.page-btn { padding: 6px 12px; border: 1px solid #e5e5e5; border-radius: 4px; background: #fff; cursor: pointer; font-size: 0.9rem; }\n.page-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); }\n    }\n}\n\n/* From Template-Standard-Stats-Dashboard-body-component.html */\n@layer components.stats_dashboard {\n    .c-stats-dashboard {\n        * { box-sizing: border-box; }\n        body { margin:0; padding:0; font-family:'Inter',sans-serif; 