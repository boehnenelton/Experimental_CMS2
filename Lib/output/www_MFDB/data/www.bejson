    display: block;\n        }\n\n        .sidebar-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 24px;\n        }\n\n        .sidebar-title {\n            font-weight: 600;\n            font-size: 1.25rem;\n            color: #1a1a1a;\n        }\n\n        .close-sidebar {\n            cursor: pointer;\n            font-weight: 600;\n            font-size: 1.2rem;\n            color: #1a1a1a;\n        }\n\n        /* Responsive */\n        @container (max-width: 768px) {\n            body {\n                /* Add 100px padding at the bottom to account for browser toolbars and the docked footer */\n                padding-bottom: 100px; \n            }\n            .container {\n                grid-template-columns: 1fr;\n            }\n            .left-column, .right-column {\n                display: none;\n            }\n            .global-docked-footer {\n                padding-bottom: calc(16px + env(safe-area-inset-bottom));\n            }\n        }\n    }\n}\n\n/* From Template-Standard-Changelog-body-component.html */\n@layer components.changelog {\n    .c-changelog {\n        * {\n            box-sizing: border-box;\n        }\n        \n        body {\n            margin: 0;\n            padding: 0;\n            font-family: 'Inter', sans-serif;\n            background-color: #ffffff;\n            color: #1a1a1a;\n            /* Extra padding at the bottom for desktop, overridden on mobile */\n            padding-bottom: 60px; \n        }\n\n        /* Colors & Links */\n        a {\n            color: var(--primary);\n            text-decoration: none;\n        }\n\n        a:hover {\n            text-decoration: underline;\n        }\n\n        .emphasis {\n            color: var(--primary);\n        }\n\n        /* Header Section */\n        header {\n            display: flex;\n            align-items: center;\n            padding: 12px 24px;\n       